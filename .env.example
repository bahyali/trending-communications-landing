# Copy this file to .env and fill in the values for your machine.
# .env is gitignored so each developer keeps their own.

# Cloudflare account to deploy under. Only required if your wrangler
# session has access to more than one account; otherwise wrangler picks
# the only available account automatically.
# Find yours via `npx wrangler whoami` or on dash.cloudflare.com.
CLOUDFLARE_ACCOUNT_ID=
